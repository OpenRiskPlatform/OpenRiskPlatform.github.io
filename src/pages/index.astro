---
import "../styles/globals.css";
import {
  SDK_URL,
  DISCOVERY_URL,
  APP_GITHUB_URL,
  GITHUB_URL,
} from "../../site.config.ts";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const features = [
  {
    title: "Local-first",
    desc: "All data stays on your machine. Projects are SQLite databases stored where you choose — no cloud sync, no telemetry.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20 17a2 2 0 0 0 .001-4H17V9a5 5 0 0 0-9.9-1H7a4 4 0 0 0 0 8h1"/><polyline points="13 15 10 18 13 21"/></svg>`,
  },
  {
    title: "Encrypted projects",
    desc: "Project databases are encrypted with SQLCipher. Your investigations stay private even if the file is copied.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
  },
  {
    title: "Plugin ecosystem",
    desc: "Install plugins directly from the UI. Every plugin speaks the same typed data model — mix and match sources freely.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/></svg>`,
  },
  {
    title: "Structured results",
    desc: "Every source returns the same entity types — person, organization, riskTopic — so results are comparable and storable.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
  {
    title: "Scan history",
    desc: "Every investigation is stored with its results. Revisit, compare, and export previous scans without re-running them.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    title: "Open source",
    desc: "Core application and official plugins are open source. Audit the code, fork it, or build internal plugins that never leave your org.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  },
];

const integrations = [
  {
    name: "Adversea",
    id: "adversea",
    category: "Risk Screening",
    desc: "PEP & sanctions screening, adverse media topic reports, and URL-level unit analysis. Slovakia/CEE focus.",
    entrypoints: ["pep-sanctions", "topic-report", "unit-analysis"],
  },
  {
    name: "OpenCorporates",
    id: "opencorporates",
    category: "Company Data",
    desc: "Search companies and officers across the world's largest open company database — 200+ jurisdictions.",
    entrypoints: ["companies", "officers"],
  },
  {
    name: "OpenSanctions",
    id: "opensanctions",
    category: "Watchlist Screening",
    desc: "Match persons and entities against consolidated global watchlists with scoring metadata.",
    entrypoints: ["search"],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OpenRisk — Risk Intelligence Platform</title>
    <meta name="description" content="OpenRisk is a local-first risk intelligence platform with a plugins ecosystem for connecting PEP/sanctions databases, company registers, and adverse media sources." />
    <link rel="icon" type="image/svg+xml" href={base + "/favicon.svg"} />
  </head>
  <body>
    <!-- Dark mode init -->
    <script is:inline>
      (function () {
        const s = localStorage.getItem("theme");
        const p = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (s === "dark" || (!s && p)) document.documentElement.classList.add("dark");
      })();
    </script>

    <!-- ── NAV ─────────────────────────────────────────────── -->
    <header class="sticky top-0 z-50 border-b border-border bg-background/90 backdrop-blur">
      <div class="mx-auto flex h-14 max-w-6xl items-center gap-6 px-4">
        <a href={base + "/"} class="flex items-center gap-2 font-semibold text-sm">
          <span class="text-base">⬡</span>
          <span>OpenRisk</span>
        </a>
        <nav class="hidden sm:flex items-center gap-1 text-sm">
          <a href="#problem" class="px-3 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-accent/50 transition-colors">Problem</a>
          <a href="#data-model" class="px-3 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-accent/50 transition-colors">Data Model</a>
          <a href="#plugins" class="px-3 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-accent/50 transition-colors">Plugins</a>
          <a href="#integrations" class="px-3 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-accent/50 transition-colors">Integrations</a>
          <a href="#ecosystem" class="px-3 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-accent/50 transition-colors">Ecosystem</a>
        </nav>
        <div class="ml-auto flex items-center gap-3 text-xs text-muted-foreground">
          <a href={DISCOVERY_URL} target="_blank" rel="noreferrer" class="hover:text-foreground transition-colors hidden sm:inline">Plugins ↗</a>
          <a href={SDK_URL} target="_blank" rel="noreferrer" class="hover:text-foreground transition-colors hidden sm:inline">SDK ↗</a>
          <a href={APP_GITHUB_URL} target="_blank" rel="noreferrer" class="hover:text-foreground transition-colors">GitHub ↗</a>
          <button id="theme-toggle" aria-label="Toggle dark mode" class="rounded-md p-1.5 hover:bg-accent/50 transition-colors">
            <span id="theme-icon">☾</span>
          </button>
        </div>
      </div>
    </header>

    <!-- ── HERO ───────────────────────────────────────────── -->
    <section class="relative overflow-hidden py-24 sm:py-32">
      <div class="mx-auto max-w-5xl px-4 text-center">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border px-4 py-1.5 text-xs text-muted-foreground">
          <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
          local-first · open plugins · encrypted projects
        </div>
        <h1 class="text-5xl sm:text-6xl font-bold tracking-tight leading-tight">
          Risk Intelligence<br />
          <span style="color: hsl(var(--brand))">Platform</span>
        </h1>
        <p class="mt-6 max-w-2xl mx-auto text-lg text-muted-foreground leading-relaxed">
          OpenRisk automates risk investigations across PEP/sanctions databases, company registers,
          adverse media, and more — all running locally on your machine.
        </p>
        <div class="mt-10 flex flex-wrap gap-3 justify-center">
          <a
            href={APP_GITHUB_URL}
            target="_blank"
            rel="noreferrer"
            class="rounded-lg bg-primary text-primary-foreground px-6 py-3 text-sm font-semibold hover:opacity-90 transition-opacity"
          >
            Download OpenRisk ↓
          </a>
          <a
            href={DISCOVERY_URL}
            target="_blank"
            rel="noreferrer"
            class="rounded-lg border border-border bg-background px-6 py-3 text-sm font-semibold hover:bg-accent transition-colors"
          >
            Browse Plugins →
          </a>
          <a
            href={SDK_URL}
            target="_blank"
            rel="noreferrer"
            class="rounded-lg border border-border bg-background px-6 py-3 text-sm font-semibold hover:bg-accent transition-colors"
          >
            Plugin SDK →
          </a>
        </div>
      </div>
    </section>

    <!-- ── PROBLEM ────────────────────────────────────────── -->
    <section id="problem" class="py-20 border-t border-border">
      <div class="mx-auto max-w-5xl px-4">
        <div class="grid gap-12 lg:grid-cols-2 items-center">
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest" style="color: hsl(var(--brand))">Problem</p>
            <h2 class="text-3xl font-bold tracking-tight mb-6">Manual investigation is slow</h2>
            <ul class="flex flex-col gap-4 text-muted-foreground">
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-foreground/40"></span>
                <span>Analysts juggle <strong class="text-foreground">dozens of sources</strong> — sanctions lists, company registers, PEP databases, adverse media, local registries.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-foreground/40"></span>
                <span>Integration happens <strong class="text-foreground">through Word and Excel</strong> — copy/paste from browser tabs, manual formatting.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-foreground/40"></span>
                <span>No audit trail. No structure. <strong class="text-foreground">No automation.</strong></span>
              </li>
            </ul>
          </div>
          <!-- Sources diagram -->
          <div class="relative flex flex-col gap-3 rounded-xl border border-border p-6 bg-muted/30">
            <div class="text-xs font-semibold text-muted-foreground mb-2 uppercase tracking-widest">Analyst workflow today</div>
            {[
              { icon: "🏦", label: "Sanctions lists" },
              { icon: "🏢", label: "Company registers" },
              { icon: "👤", label: "PEP databases" },
              { icon: "📰", label: "Adverse media" },
              { icon: "📋", label: "Local registries" },
            ].map((src) => (
              <div class="flex items-center gap-3">
                <span class="text-xl">{src.icon}</span>
                <span class="text-sm">{src.label}</span>
                <span class="ml-auto text-xs text-muted-foreground font-mono">ctrl+c · ctrl+v</span>
              </div>
            ))}
            <div class="mt-4 border-t border-border pt-4 flex items-center justify-center gap-4 text-sm text-muted-foreground">
              <span>📄 Word</span>
              <span>→</span>
              <span>📊 Excel</span>
              <span>→</span>
              <span>😩 Report</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── DATA MODEL ─────────────────────────────────────── -->
    <section id="data-model" class="py-20 border-t border-border">
      <div class="mx-auto max-w-5xl px-4">
        <div class="grid gap-12 lg:grid-cols-2 items-start">
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest" style="color: hsl(var(--brand))">Data Model</p>
            <h2 class="text-3xl font-bold tracking-tight mb-6">Common language for results</h2>
            <p class="text-muted-foreground mb-6 leading-relaxed">
              Every plugin speaks the same structured format. Results are typed entities — person, organization, risk topic, sanction — with normalized props and raw extra data from the source.
            </p>
            <div class="flex flex-col gap-3">
              {[
                { key: "type", desc: "What kind of result — entity, annotation, metric…" },
                { key: "entity", desc: "Semantic type: person, organization, riskTopic…" },
                { key: "props", desc: "Normalized fields with stable, typed keys." },
                { key: "extra", desc: "Raw source data preserved as-is." },
              ].map((item) => (
                <div class="flex items-start gap-3">
                  <code class="shrink-0 rounded bg-muted px-2 py-0.5 text-xs font-mono mt-0.5">{item.key}</code>
                  <span class="text-sm text-muted-foreground">{item.desc}</span>
                </div>
              ))}
            </div>
            <div class="mt-6">
              <a
                href={SDK_URL + "/entities/"}
                target="_blank"
                rel="noreferrer"
                class="text-sm font-medium hover:underline"
                style="color: hsl(var(--brand))"
              >
                Browse all entity types in the SDK →
              </a>
            </div>
          </div>
          <!-- Code block -->
          <div class="rounded-xl border border-border overflow-hidden">
            <div class="flex items-center gap-2 border-b border-border bg-muted/50 px-4 py-2.5">
              <div class="h-2.5 w-2.5 rounded-full bg-red-400"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-yellow-400"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-green-400"></div>
              <span class="ml-2 text-xs font-mono text-muted-foreground">plugin-output.json</span>
            </div>
            <pre class="p-5 text-xs leading-relaxed overflow-x-auto bg-[hsl(224,71.4%,4.1%)] text-[hsl(210,20%,95%)]"><code>{`{
  "dataModelVersion": "v1",
  "results": [
    {
      "type": "entity",
      "entity": "person",
      "props": {
        "name": "Richard Marko",
        "birthDate": "1974-08-18"
      },
      "extra": {
        "source": "OpenCorporates",
        "confidence": 0.91
      }
    }
  ]
}`}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PLUGIN MODEL ───────────────────────────────────── -->
    <section id="plugins" class="py-20 border-t border-border" style="background: hsl(var(--muted)/30%)">
      <div class="mx-auto max-w-5xl px-4">
        <div class="mb-12 text-center">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest" style="color: hsl(var(--brand))">Plugin Model</p>
          <h2 class="text-3xl font-bold tracking-tight">Plugin as a function</h2>
          <p class="mt-4 max-w-xl mx-auto text-muted-foreground leading-relaxed">
            A plugin is a TypeScript file with two inputs and one output. No framework. No dependencies. Just a function that calls an API and normalizes the result.
          </p>
        </div>
        <div class="grid gap-6 sm:grid-cols-3 mb-10">
          {[
            { label: "input", icon: "→", desc: "Search term, entity name, or structured query from the user." },
            { label: "settings", icon: "⚙", desc: "Per-plugin configuration: API keys, tokens, preferences." },
            { label: "data model", icon: "✓", desc: "Typed entity array returned to OpenRisk for display and storage." },
          ].map((item) => (
            <div class="rounded-xl border border-border bg-background p-5">
              <div class="mb-3 flex items-center gap-2">
                <span class="text-lg">{item.icon}</span>
                <code class="text-sm font-semibold font-mono">{item.label}</code>
              </div>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          ))}
        </div>
        <!-- Code snippet -->
        <div class="rounded-xl border border-border overflow-hidden">
          <div class="flex items-center gap-2 border-b border-border bg-muted/50 px-4 py-2.5">
            <div class="h-2.5 w-2.5 rounded-full bg-red-400"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-yellow-400"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-green-400"></div>
            <span class="ml-2 text-xs font-mono text-muted-foreground">index.ts</span>
          </div>
          <pre class="p-5 text-xs leading-relaxed overflow-x-auto bg-[hsl(224,71.4%,4.1%)] text-[hsl(210,20%,95%)]"><code>{`export async function run(input: string, settings: Settings) {
  const raw = await mySource.search(input, settings.apiKey);
  return normalizeToOpenRisk(raw);
}

function normalizeToOpenRisk(raw: SourceResult[]) {
  return raw.map((r) => ({
    type: "entity",
    entity: "person",
    props: { name: r.fullName, birthDate: r.dob },
    extra: { sourceId: r.id, score: r.confidence },
  }));
}`}</code></pre>
        </div>
        <div class="mt-6 text-center">
          <a
            href={SDK_URL}
            target="_blank"
            rel="noreferrer"
            class="text-sm font-medium hover:underline"
            style="color: hsl(var(--brand))"
          >
            Read the Plugin SDK docs →
          </a>
        </div>
      </div>
    </section>

    <!-- ── INTEGRATIONS ───────────────────────────────────── -->
    <section id="integrations" class="py-20 border-t border-border">
      <div class="mx-auto max-w-5xl px-4">
        <div class="mb-12 text-center">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest" style="color: hsl(var(--brand))">Integrations</p>
          <h2 class="text-3xl font-bold tracking-tight">Connected to existing sources</h2>
          <p class="mt-4 max-w-xl mx-auto text-muted-foreground leading-relaxed">
            Official plugins connect to the leading risk intelligence and corporate data providers.
          </p>
        </div>
        <div class="grid gap-6 sm:grid-cols-3">
          <!-- Adversea -->
          <div class="rounded-xl border border-border bg-[hsl(224,71.4%,4.1%)] text-white p-6 flex flex-col gap-3">
            <div class="text-2xl font-bold tracking-tight text-teal-400">adversea</div>
            <p class="text-sm text-white/70 leading-snug flex-1">
              PEP & sanctions screening, adverse media topic reports, and URL-level unit analysis.
            </p>
            <div class="text-xs font-semibold text-teal-400 uppercase tracking-widest">risk screening</div>
          </div>
          <!-- OpenCorporates -->
          <div class="rounded-xl border border-border bg-background p-6 flex flex-col gap-3">
            <div class="text-2xl font-bold tracking-tight">
              <span class="text-red-600">open</span>corporates
            </div>
            <p class="text-sm text-muted-foreground leading-snug flex-1">
              Search companies and officers across the world's largest open company database.
            </p>
            <div class="text-xs font-semibold text-muted-foreground uppercase tracking-widest">company data</div>
          </div>
          <!-- OpenSanctions -->
          <div class="rounded-xl border border-border bg-background p-6 flex flex-col gap-3">
            <div class="text-2xl font-bold tracking-tight text-blue-600">
              open<span class="text-foreground">sanctions</span>
            </div>
            <p class="text-sm text-muted-foreground leading-snug flex-1">
              Match persons and entities against consolidated global watchlists with scoring metadata.
            </p>
            <div class="text-xs font-semibold text-muted-foreground uppercase tracking-widest">watchlist screening</div>
          </div>
        </div>
        <div class="mt-8 text-center">
          <a
            href={DISCOVERY_URL}
            target="_blank"
            rel="noreferrer"
            class="text-sm font-medium hover:underline"
            style="color: hsl(var(--brand))"
          >
            All plugins in the registry →
          </a>
        </div>
      </div>
    </section>

    <!-- ── ECOSYSTEM ──────────────────────────────────────── -->
    <section id="ecosystem" class="py-20 border-t border-border" style="background: hsl(var(--muted)/30%)">
      <div class="mx-auto max-w-5xl px-4">
        <div class="mb-12 text-center">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest" style="color: hsl(var(--brand))">Developer Ecosystem</p>
          <h2 class="text-3xl font-bold tracking-tight">Build your own plugin</h2>
          <p class="mt-4 max-w-xl mx-auto text-muted-foreground leading-relaxed">
            The plugin SDK provides everything you need: typed data model, manifest reference, live validator, and template examples.
          </p>
        </div>
        <div class="grid gap-6 sm:grid-cols-3">
          {[
            {
              kicker: "DOCS",
              title: "Model, Manifest & Workflow",
              desc: "Complete reference for the data model, plugin manifest schema, and development workflow.",
              href: SDK_URL,
              label: "Open SDK Docs →",
            },
            {
              kicker: "EXAMPLES",
              title: "Plugin Templates",
              desc: "Annotated plugin templates you can copy and adapt as a starting point.",
              href: SDK_URL + "/manifest/",
              label: "View Templates →",
            },
            {
              kicker: "VALIDATION",
              title: "Check Before Shipping",
              desc: "Paste your plugin output JSON and validate it against the data model schema in the browser.",
              href: SDK_URL + "/validate/",
              label: "Open Validator →",
            },
          ].map((card) => (
            <div class="rounded-xl border border-border bg-background p-6 flex flex-col gap-3">
              <p class="text-xs font-semibold uppercase tracking-widest" style="color: hsl(var(--brand))">{card.kicker}</p>
              <h3 class="font-semibold text-base">{card.title}</h3>
              <p class="text-sm text-muted-foreground leading-snug flex-1">{card.desc}</p>
              <a href={card.href} target="_blank" rel="noreferrer" class="text-sm font-medium hover:underline mt-auto" style="color: hsl(var(--brand))">{card.label}</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── PRINCIPLES ─────────────────────────────────────── -->
    <section id="principles" class="py-20 border-t border-border">
      <div class="mx-auto max-w-5xl px-4">
        <div class="grid gap-12 lg:grid-cols-2 items-center">
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest" style="color: hsl(var(--brand))">Principles</p>
            <h2 class="text-3xl font-bold tracking-tight mb-6">Platform features</h2>
            <div class="flex flex-col gap-5">
              {[
                {
                  icon: "💾",
                  title: "Local-first workflow",
                  desc: "All data stays on your machine. Projects are SQLite databases stored where you choose.",
                },
                {
                  icon: "🔒",
                  title: "Encrypted projects",
                  desc: "Project databases are encrypted with SQLCipher. Your investigations stay private.",
                },
                {
                  icon: "🔌",
                  title: "Plugins via UI",
                  desc: "Install, configure, and run plugins directly from the OpenRisk interface — no CLI needed.",
                },
              ].map((item) => (
                <div class="flex items-start gap-4">
                  <span class="text-2xl shrink-0 mt-0.5">{item.icon}</span>
                  <div>
                    <div class="font-semibold text-sm mb-1">{item.title}</div>
                    <p class="text-sm text-muted-foreground">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <!-- App screenshot placeholder -->
          <div class="rounded-xl border border-border bg-muted/30 p-8 flex items-center justify-center aspect-video">
            <div class="text-center text-muted-foreground">
              <div class="text-4xl mb-3">⬡</div>
              <div class="text-sm font-medium">OpenRisk App</div>
              <div class="text-xs mt-1">Tauri · Rust · React</div>
              <a
                href={APP_GITHUB_URL}
                target="_blank"
                rel="noreferrer"
                class="mt-4 inline-block text-xs font-medium hover:underline"
                style="color: hsl(var(--brand))"
              >
                View on GitHub ↗
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────── -->
    <section class="py-24 border-t border-border text-center">
      <div class="mx-auto max-w-2xl px-4">
        <h2 class="text-3xl font-bold tracking-tight mb-4">Ready to start?</h2>
        <p class="text-muted-foreground mb-8 leading-relaxed">
          Download OpenRisk, explore plugins, or build your own integration using the SDK.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href={APP_GITHUB_URL}
            target="_blank"
            rel="noreferrer"
            class="rounded-lg bg-primary text-primary-foreground px-6 py-3 text-sm font-semibold hover:opacity-90 transition-opacity"
          >
            Download OpenRisk ↓
          </a>
          <a
            href={DISCOVERY_URL}
            target="_blank"
            rel="noreferrer"
            class="rounded-lg border border-border bg-background px-6 py-3 text-sm font-semibold hover:bg-accent transition-colors"
          >
            Browse Plugins
          </a>
          <a
            href={SDK_URL}
            target="_blank"
            rel="noreferrer"
            class="rounded-lg border border-border bg-background px-6 py-3 text-sm font-semibold hover:bg-accent transition-colors"
          >
            Plugin SDK
          </a>
        </div>
      </div>
    </section>

    <!-- ── FOOTER ─────────────────────────────────────────── -->
    <footer class="border-t border-border py-10 text-center text-xs text-muted-foreground">
      <div class="flex items-center justify-center gap-5 flex-wrap">
        <span>© 2026 OpenRisk Platform</span>
        <a href={APP_GITHUB_URL} target="_blank" rel="noreferrer" class="hover:text-foreground transition-colors">GitHub</a>
        <a href={SDK_URL} target="_blank" rel="noreferrer" class="hover:text-foreground transition-colors">Plugin SDK</a>
        <a href={DISCOVERY_URL} target="_blank" rel="noreferrer" class="hover:text-foreground transition-colors">Plugin Registry</a>
      </div>
    </footer>

    <script is:inline>
      const btn = document.getElementById("theme-toggle");
      const icon = document.getElementById("theme-icon");
      function syncIcon() {
        icon.textContent = document.documentElement.classList.contains("dark") ? "☀" : "☾";
      }
      syncIcon();
      btn.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        syncIcon();
      });
    </script>
  </body>
</html>
